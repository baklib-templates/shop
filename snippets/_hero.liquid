{% assign default_hero_image = 'images/hero.jpg' | asset_url %}
{% assign screen_width = 'max-w-screen-2xl' %}

<!-- Hero Section -->
<section id="hero" class="flex items-center justify-center flex-col bg-no-repeat bg-cover bg-center bg-accent h-[250px]  {% if screen_width == 'max-w-screen-2xl' %}  md:h-[400px] {% else %}  md:h-[300px] {%- endif -%}"
  style="background-image: url({{ page.settings.hero_image_url | default: default_hero_image }}); color: {{ page.settings.text_color | default: '#ffffff' }};">
  <div class="flex items-center justify-center flex-1 w-full py-3">
    <div class="container flex flex-col h-full px-4 mx-auto">
      <div class="flex flex-col items-center justify-center flex-grow">
        <h1 class="py-2 mt-12 text-2xl md:text-4xl font-bold transition duration-500 md:mt-0 text-shadow">
          {{ site.name }}
        </h1>
        <p class="py-2 text-base transition duration-500 text-shadow">{{ page.settings.description }}</p>

        <div class="z-0 flex flex-col items-center justify-center w-full md:w-1/2">
          {% form_tag 'search', class: 'w-full' %}
            <div class="relative rounded-box shadow-sm">
              <button type="submit" class="absolute inset-y-0 right-0 flex items-center pl-4 pr-3 sm:right-auto">
                <i data-lucide="search" class="h-5 w-5 text-primary"></i>
              </button>
              <input
                type="text"
                name="{{form.keywords_field_name}}" value="{{ search.keywords | escape_once }}"
                placeholder="{{ "placeholders.search" | t }}"
                autocomplete="off"
                class="block text-base-content w-full h-10 md:h-12 lg:h-14 pl-3 pr-10 transition duration-300 ease-in-out bg-white bg-opacity-75 border border-transparent rounded-lg outline-none focus:ring-0 focus:border-primary sm:pl-12 sm:text-lg focus:bg-opacity-90"
              >
            </div>
          {% endform_tag %}

        <!-- Hot tags -->
          {% assign hot_tags_count = page.settings.tags | size %}
          {% if hot_tags_count > 0 %}
            <div class="md:flex flex-wrap items-center justify-center hidden w-full mt-4">
              <div class="inline-block">
                {% for tag in page.settings.tags %}
                  <a
                    href="{{ tag.path }}"
                    data-turbo-frame="_top"
                    class="mr-3 hover:underline focus:ring hover:-translate-y-[2px] min-w-12"
                  >
                    {{ tag.name }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% endif %}

        </div>
      </div>
    </div>
  </div>
</section>
